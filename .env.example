# Copy to .env.local for local dev.
# For Vercel: Project Settings → Environment Variables (same names).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Login — use a unique random string for AUTH_SESSION_TOKEN (e.g. openssl rand -hex 32)
AUTH_USERNAME=admin
AUTH_PASSWORD=nixon
AUTH_SESSION_TOKEN=your_random_64_char_hex_string
